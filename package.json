{
  "name": "astro-history",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"tsx watch astro-server/index.ts\" \"vite\"",
    "dev:server": "tsx watch astro-server/index.ts",
    "dev:client": "vite",
    "build:client": "tsc -p tsconfig.app.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@radix-ui/react-slot": "^1.1.0",
